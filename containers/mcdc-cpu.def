Bootstrap: docker
From: python:3.11-slim

%labels
    org.opencontainers.image.source https://github.com/CEMeNT-PSAAP/MCDC
    org.opencontainers.image.description "MC/DC: Monte Carlo Dynamic Code (CPU)"
    org.opencontainers.image.licenses BSD-3-Clause

%environment
    export PYTHONPATH=/opt/mcdc:$PYTHONPATH

%files
    # Copy entire repo into container at build time
    . /opt/mcdc

%post
    apt-get update && apt-get install -y \
        gcc g++ libopenmpi-dev openmpi-bin git \
        && rm -rf /var/lib/apt/lists/*
    pip install --no-cache-dir mpi4py
    cd /opt/mcdc && pip install --no-cache-dir -e ".[dev]"

%runscript
    exec python "$@"

%test
    python -c "import mcdc; print('MC/DC CPU OK')"